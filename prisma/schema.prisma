generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                   String
  email                  String         @unique
  passwordHash           String?        @map("password_hash")
  phone                  String?
  avatarUrl              String?        @map("avatar_url")
  role                   String         @default("agent")
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")
  passwordResetTokenHash String?        @unique @map("password_reset_token_hash")
  passwordResetExpiresAt DateTime?      @map("password_reset_expires_at") @db.Timestamptz(6)
  googleId               String?        @unique @map("google_id")
  activities             Activity[]
  leadActions            LeadAction[]
  leads                  Lead[]
  tasks                  Task[]
  settings               UserSettings?

  @@map("users")
}

model UserSettings {
  id                   String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String  @unique @map("user_id") @db.Uuid
  whatsappPhoneId      String? @map("whatsapp_phone_id")
  whatsappToken        String? @map("whatsapp_token")
  whatsappWebhookToken String? @map("whatsapp_webhook_token")
  aiProvider           String  @default("openai") @map("ai_provider")
  aiApiKey             String? @map("ai_api_key")
  aiModel              String  @default("gpt-4o-mini") @map("ai_model")
  greetingMessage      String? @map("greeting_message")
  autoReplyEnabled     Boolean @default(true) @map("auto_reply_enabled")
  followUpEnabled      Boolean @default(true) @map("follow_up_enabled")
  followUpDelayHours   Int     @default(24) @map("follow_up_delay_hours")
  maxFollowUps         Int     @default(3) @map("max_follow_ups")
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Lead {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String         @map("user_id") @db.Uuid
  name            String
  phone           String
  email           String?
  avatarUrl       String?        @map("avatar_url")
  source          String         @default("whatsapp")
  status          String         @default("new")
  score           Int            @default(0)
  value           Decimal?       @db.Decimal(12, 2)
  region          String?
  priceMin        Decimal?       @map("price_min") @db.Decimal(12, 2)
  priceMax        Decimal?       @map("price_max") @db.Decimal(12, 2)
  propertyType    String?        @map("property_type")
  purpose         String?
  timeline        String?
  bedrooms        Int?
  notes           String?
  pipelineStageId String?        @map("pipeline_stage_id") @db.Uuid
  lastContactAt   DateTime?      @map("last_contact_at")
  nextFollowUpAt  DateTime?      @map("next_follow_up_at")
  followUpCount   Int            @default(0) @map("follow_up_count")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  activities      Activity[]
  conversation    Conversation?
  leadActions     LeadAction[]
  pipelineStage   PipelineStage? @relation(fields: [pipelineStageId], references: [id])
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks           Task[]

  @@index([userId, status])
  @@index([userId, score(sort: Desc)])
  @@index([nextFollowUpAt])
  @@map("leads")
}

model Conversation {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId         String    @unique @map("lead_id") @db.Uuid
  whatsappChatId String?   @map("whatsapp_chat_id")
  status         String    @default("active")
  unreadCount    Int       @default(0) @map("unread_count")
  lastMessageAt  DateTime? @map("last_message_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  lead           Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  messages       Message[]

  @@map("conversations")
}

model Message {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  direction      String
  sender         String
  content        String
  type           String       @default("text")
  status         String       @default("sent")
  whatsappMsgId  String?      @map("whatsapp_msg_id")
  metadata       Json?
  createdAt      DateTime     @default(now()) @map("created_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, whatsappMsgId])
  @@index([conversationId, createdAt])
  @@map("messages")
}

model PipelineStage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String
  color     String   @default("blue")
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  leads     Lead[]

  @@unique([userId, order])
  @@map("pipeline_stages")
}

model Activity {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  leadId      String?  @map("lead_id") @db.Uuid
  type        String
  title       String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@map("activities")
}

model Task {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  leadId      String?   @map("lead_id") @db.Uuid
  type        String    @default("follow_up")
  title       String
  description String?
  status      String    @default("pending")
  dueAt       DateTime  @map("due_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  lead        Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, dueAt])
  @@index([leadId])
  @@map("tasks")
}

model LeadAction {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  leadId      String    @map("lead_id") @db.Uuid
  type        String    @db.VarChar
  status      String    @default("pending") @db.VarChar
  title       String    @db.VarChar
  notes       String?
  origin      String    @default("manual") @db.VarChar
  scheduledAt DateTime? @map("scheduled_at") @db.Timestamptz(6)
  reminderAt  DateTime? @map("reminder_at") @db.Timestamptz(6)
  completedAt DateTime? @map("completed_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([leadId, type, status], map: "idx_lead_actions_lead_type_status")
  @@index([userId, status, scheduledAt], map: "idx_lead_actions_user_status_scheduled")
  @@map("lead_actions")
}
