generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                   String
  email                  String                 @unique
  passwordHash           String?                @map("password_hash")
  phone                  String?
  avatarUrl              String?                @map("avatar_url")
  role                   String                 @default("agent")
  createdAt              DateTime               @default(now()) @map("created_at")
  updatedAt              DateTime               @updatedAt @map("updated_at")
  passwordResetTokenHash String?                @unique @map("password_reset_token_hash")
  passwordResetExpiresAt DateTime?              @map("password_reset_expires_at") @db.Timestamptz(6)
  googleId               String?                @unique @map("google_id")
  tenantId               String?                @map("tenant_id") @db.Uuid
  status                 String                 @default("active") @db.VarChar(20)
  token_version          Int                    @default(0)
  activities             Activity[]
  appointments           appointments[]
  calendar_connections   calendar_connections[]
  facebookPages          FacebookPageMapping[]
  leadActions            LeadAction[]
  leads                  Lead[]
  properties             properties[]
  settings               UserSettings?
  tenant                 Tenant?                @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  voiceReplyUsage        VoiceReplyUsage[]

  @@index([tenantId], map: "idx_users_tenant_id")
  @@map("users")
}

model UserSettings {
  id                         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                     String    @unique @map("user_id") @db.Uuid
  whatsappPhoneId            String?   @map("whatsapp_phone_id")
  whatsappToken              String?   @map("whatsapp_token")
  whatsappWebhookToken       String?   @map("whatsapp_webhook_token")
  aiProvider                 String    @default("openai") @map("ai_provider")
  aiApiKey                   String?   @map("ai_api_key")
  aiModel                    String    @default("gpt-4o-mini") @map("ai_model")
  campaignOutreachMessage    String?   @map("campaign_outreach_message")
  autoReplyEnabled           Boolean   @default(true) @map("auto_reply_enabled")
  followUpEnabled            Boolean   @default(true) @map("follow_up_enabled")
  followUpDelayHours         Int       @default(24) @map("follow_up_delay_hours")
  maxFollowUps               Int       @default(3) @map("max_follow_ups")
  auto_reply_delay_seconds   Int       @default(0)
  facebookPageAccessToken    String?   @map("facebook_page_access_token")
  facebookAutoOutreach       Boolean   @default(true) @map("facebook_auto_outreach")
  openaiTranscriptionKey     String?   @map("openai_transcription_key")
  elevenlabsVoiceId          String?   @map("elevenlabs_voice_id")
  voiceReplyEnabled          Boolean   @default(false) @map("voice_reply_enabled")
  voiceReplyMonthlyLimit     Int       @default(50) @map("voice_reply_monthly_limit")
  whatsapp_provider          String    @default("evolution") @db.VarChar(30)
  followUpCustomInstructions String?   @map("follow_up_custom_instructions")
  canalProWebhookToken       String?   @unique @map("canal_pro_webhook_token") @db.VarChar
  canalProAutoOutreach       Boolean   @default(true) @map("canal_pro_auto_outreach")
  canalProAccountType        String    @default("own") @map("canal_pro_account_type") @db.VarChar(20)
  gmailAccessToken           String?   @map("gmail_access_token")
  gmailRefreshToken          String?   @map("gmail_refresh_token")
  gmailTokenExpiresAt        DateTime? @map("gmail_token_expires_at") @db.Timestamptz(6)
  campaignOutreachImageUrl   String?   @map("campaign_outreach_image_url")
  campaignSecondMessage      String?   @map("campaign_second_message")
  campaignSecondImageUrl     String?   @map("campaign_second_image_url")
  user                       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model FacebookPageMapping {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pageId    String   @unique @map("page_id")
  userId    String   @map("user_id") @db.Uuid
  pageName  String?  @map("page_name")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("facebook_page_mappings")
}

model Lead {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String         @map("user_id") @db.Uuid
  name            String
  phone           String
  email           String?
  avatarUrl       String?        @map("avatar_url")
  source          String         @default("whatsapp")
  status          String         @default("new")
  score           Int            @default(0)
  value           Decimal?       @db.Decimal(12, 2)
  region          String?
  priceMin        Decimal?       @map("price_min") @db.Decimal(12, 2)
  priceMax        Decimal?       @map("price_max") @db.Decimal(12, 2)
  propertyType    String?        @map("property_type")
  purpose         String?
  timeline        String?
  bedrooms        Int?
  notes           String?
  pipelineStageId String?        @map("pipeline_stage_id") @db.Uuid
  lastContactAt   DateTime?      @map("last_contact_at")
  nextFollowUpAt  DateTime?      @map("next_follow_up_at")
  followUpCount   Int            @default(0) @map("follow_up_count")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  activities      Activity[]
  appointments    appointments[]
  conversation    Conversation?
  leadActions     LeadAction[]
  pipelineStage   PipelineStage? @relation(fields: [pipelineStageId], references: [id])
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, score(sort: Desc)])
  @@index([nextFollowUpAt])
  @@index([nextFollowUpAt], map: "idx_leads_next_follow_up")
  @@index([lastContactAt], map: "idx_leads_last_contact")
  @@map("leads")
}

model Conversation {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId                   String    @unique @map("lead_id") @db.Uuid
  whatsappChatId           String?   @map("whatsapp_chat_id")
  status                   String    @default("active")
  unreadCount              Int       @default(0) @map("unread_count")
  lastMessageAt            DateTime? @map("last_message_at")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")
  awaitingCampaignResponse Boolean   @default(false) @map("awaiting_campaign_response")
  lead                     Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  messages                 Message[]

  @@map("conversations")
}

model Message {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  direction      String
  sender         String
  content        String
  type           String       @default("text")
  status         String       @default("sent")
  whatsappMsgId  String?      @map("whatsapp_msg_id")
  metadata       Json?
  createdAt      DateTime     @default(now()) @map("created_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, whatsappMsgId])
  @@index([conversationId, createdAt])
  @@map("messages")
}

model PipelineStage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String
  color     String   @default("blue")
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  leads     Lead[]

  @@unique([userId, order])
  @@map("pipeline_stages")
}

model Activity {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  leadId      String?  @map("lead_id") @db.Uuid
  type        String
  title       String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@map("activities")
}

model LeadAction {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String         @map("user_id") @db.Uuid
  leadId       String         @map("lead_id") @db.Uuid
  type         String         @db.VarChar
  status       String         @default("pending") @db.VarChar
  title        String         @db.VarChar
  notes        String?
  origin       String         @default("manual") @db.VarChar
  scheduledAt  DateTime?      @map("scheduled_at") @db.Timestamptz(6)
  reminderAt   DateTime?      @map("reminder_at") @db.Timestamptz(6)
  completedAt  DateTime?      @map("completed_at") @db.Timestamptz(6)
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)
  appointments appointments[]
  lead         Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([leadId, type, status], map: "idx_lead_actions_lead_type_status")
  @@index([userId, status, scheduledAt], map: "idx_lead_actions_user_status_scheduled")
  @@map("lead_actions")
}

model InviteToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  token     String   @unique @db.VarChar(64)
  email     String?  @db.VarChar(255)
  role      String   @default("agent") @db.VarChar(20)
  maxUses   Int      @default(1) @map("max_uses")
  usedCount Int      @default(0) @map("used_count")
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([token], map: "idx_invite_tokens_token")
  @@map("invite_tokens")
}

model Tenant {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug           String        @unique @db.VarChar(63)
  name           String        @db.VarChar(120)
  logoUrl        String?       @map("logo_url")
  colorPrimary   String        @default("blue") @map("color_primary") @db.VarChar(7)
  colorSecondary String        @default("purple") @map("color_secondary") @db.VarChar(7)
  status         String        @default("active") @db.VarChar(20)
  featureFlags   Json          @default("{}") @map("feature_flags")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @default(now()) @map("updated_at")
  inviteTokens   InviteToken[]
  users          User[]

  @@map("tenants")
}

model VoiceReplyUsage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  month     String   @db.VarChar(7)
  count     Int      @default(0)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, month])
  @@index([userId, month], map: "idx_voice_reply_usage_user_month")
  @@map("voice_reply_usage")
}

model properties {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String   @db.Uuid
  raw_text      String
  title         String?
  type          String?
  purpose       String?
  price         Decimal? @db.Decimal(12, 2)
  area          Decimal? @db.Decimal(8, 2)
  bedrooms      Int?
  bathrooms     Int?
  parking_spots Int?
  address       String?
  neighborhood  String?
  city          String?
  state         String?
  amenities     String[] @default([])
  description   String?
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @default(now()) @db.Timestamptz(6)
  pdf_url       String?
  pdf_filename  String?  @db.VarChar(255)
  pdf_size      Int?
  pdfs          Json     @default("[]")
  users         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, created_at(sort: Desc)], map: "Property_userId_idx")
}

model appointments {
  id                   String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id              String      @db.Uuid
  lead_id              String      @db.Uuid
  lead_action_id       String?     @db.Uuid
  title                String      @db.VarChar(255)
  scheduled_at         DateTime    @db.Timestamptz(6)
  duration_minutes     Int         @default(60)
  address              String?
  notes                String?
  status               String      @default("pending_confirmation") @db.VarChar(30)
  google_event_id      String?     @db.VarChar(255)
  google_calendar_id   String?     @db.VarChar(255)
  confirmation_sent_at DateTime?   @db.Timestamptz(6)
  confirmation_reply   String?     @db.VarChar(30)
  created_at           DateTime    @default(now()) @db.Timestamptz(6)
  updated_at           DateTime    @default(now()) @db.Timestamptz(6)
  lead_actions         LeadAction? @relation(fields: [lead_action_id], references: [id], onUpdate: NoAction)
  leads                Lead        @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                User        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([lead_id], map: "idx_appointments_lead_id")
  @@index([user_id, scheduled_at], map: "idx_appointments_user_scheduled")
  @@index([user_id, status], map: "idx_appointments_user_status")
}

model calendar_connections {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String    @db.Uuid
  provider         String    @default("google") @db.VarChar(20)
  access_token     String?
  refresh_token    String?
  token_expires_at DateTime? @db.Timestamptz(6)
  calendar_id      String    @default("primary") @db.VarChar(255)
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @db.Timestamptz(6)
  users            User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, provider])
  @@index([user_id], map: "idx_calendar_connections_user_id")
}
